# === Required ===
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx

# === Optional: Model config ===
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
# Max agent loop turns per task (default: 30, hard cap: 100)
MAX_AGENT_TURNS=30

# === Optional: Server ===
PORT=5001

# === Optional: Auth (set AUTH_ENABLED=1 to activate) ===
AUTH_ENABLED=0
JWT_SECRET=your-random-secret-at-least-32-chars-long
ADMIN_DEFAULT_PASSWORD=changeme123

# === Optional: Token budgets ===
# Per-session token budget (default: 200,000)
SESSION_TOKEN_BUDGET=200000
# Per-user daily token budget (default: 1,000,000)
DAILY_TOKEN_BUDGET=1000000

# === Optional: Security ===
# CORS_ORIGIN=http://localhost:3000
# MAX_UPLOAD_SIZE_MB=50
